    <script>
        const defaultCakes = [
            { id: 1, name: "Классический свадебный", category: "wedding", desc: "Белый бисквит с кремом, украшенный розами", fill: "Ванильный крем", price: 5000, similar: [2,3], image: "" },
            { id: 2, name: "Золотая свадьба", category: "wedding", desc: "Трёхъярусный с золотыми элементами", fill: "Шоколадный мусс", price: 8000, similar: [1], image: "" },
            { id: 3, name: "Романтика", category: "wedding", desc: "Нежный с персиками и малиной", fill: "Ягодный мусс", price: 4500, similar: [1,2], image: "" },
            { id: 4, name: "Детский день рождения", category: "kids", desc: "Яркий с любимыми героями", fill: "Шоколадный", price: 3500, similar: [5,6], image: "" },
            { id: 5, name: "Машинки", category: "kids", desc: "С шоколадными машинками", fill: "Шоколадный бисквит", price: 3000, similar: [4], image: "" },
            { id: 6, name: "Принцесса", category: "kids", desc: "Розовый с бисером и короной", fill: "Клубничный", price: 3200, similar: [4], image: "" },
            { id: 7, name: "Юбилей компании", category: "corporate", desc: "С логотипом компании", fill: "Пралине", price: 6000, similar: [8,9], image: "" },
            { id: 8, name: "Корпоратив", category: "corporate", desc: "Строгий и элегантный", fill: "Ванильный", price: 4500, similar: [7], image: "" },
            { id: 9, name: "Пралине", category: "author", desc: "Шоколад с орехами пралине", fill: "Ореховое пралине", price: 4000, similar: [10,11], image: "" },
            { id: 10, name: "Красный бархат", category: "author", desc: "Американский классический", fill: "Чизкейк", price: 3800, similar: [9], image: "" },
            { id: 11, name: "Тирамису", category: "author", desc: "Итальянский классический", fill: "Маскарпоне", price: 3800, similar: [9,10], image: "" },
            { id: 12, name: "Медовик", category: "author", desc: "Классический с мёдом", fill: "Сметанный", price: 3200, similar: [], image: "" }
        ];

        const defaultCategories = {
            wedding: "Свадебные",
            kids: "Детские",
            corporate: "Корпоративные",
            author: "Авторские"
        };

        let cakes = JSON.parse(localStorage.getItem('cakes')) || defaultCakes;
        let categories = JSON.parse(localStorage.getItem('categories')) || defaultCategories;
        let nextId = parseInt(localStorage.getItem('nextId')) || 13;
        let currentDetailCake = null;
        let tempImage = "";
        let isAdmin = false;
        let currentFilter = "all";

        function saveData() {
            localStorage.setItem('cakes', JSON.stringify(cakes));
            localStorage.setItem('categories', JSON.stringify(categories));
            localStorage.setItem('nextId', nextId);
            renderCakes(currentFilter);
            renderNav();
        }

        function renderNav() {
            const nav = document.getElementById('category-nav');
            let html = '<button data-category="all">Все</button>';
            for (let key in categories) {
                html += `<button data-category="${key}">${categories[key]}</button>`;
            }
            if (isAdmin) {
                html += '<button class="add-cat-btn" onclick="showAddCategory()">+</button>';
            }
            nav.innerHTML = html;
            
            // Set active based on currentFilter
            const activeBtn = nav.querySelector(`[data-category="${currentFilter}"]`) || nav.querySelector('[data-category="all"]');
            if (activeBtn) activeBtn.classList.add('active');
            
            // Add click handlers
            nav.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', () => {
                    if (btn.classList.contains('add-cat-btn')) return;
                    nav.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.dataset.category || "all";
                    renderCakes(currentFilter);
                });
            });
        }

        function renderCakes(filter = "all") {
            const grid = document.getElementById('cakes-grid');
            const filtered = filter === "all" || !filter ? cakes : cakes.filter(c => c.category === filter);
            
            let html = "";
            
            if (isAdmin && filter !== "all" && filter) {
                html += `<div class="add-card-btn" onclick="showAddCake('${filter}')">
                    <span>+</span>
                    <span style="font-size:1rem;margin-top:10px;">Добавить торт</span>
                </div>`;
            }
            
            html += filtered.map(cake => `
                <div class="cake-card" onclick="showDetail(${cake.id})">
                    <button class="delete-btn" onclick="event.stopPropagation();deleteCake(${cake.id})">×</button>
                    <div class="cake-image">
                        ${cake.image ? `<img src="${cake.image}" alt="${cake.name}">` : '<span class="no-image">🎂</span>'}
                    </div>
                    <div class="cake-info">
                        <div class="cake-category">${categories[cake.category] || cake.category}</div>
                        <h3 class="cake-name">${cake.name}</h3>
                        <p class="cake-desc">${cake.desc}</p>
                        <div class="cake-price">${cake.price.toLocaleString()} ₽</div>
                    </div>
                </div>
            `).join("");
            
            grid.innerHTML = html;
        }

        function showDetail(id) {
            const cake = cakes.find(c => c.id === id);
            if (!cake) return;
            currentDetailCake = cake;
            
            const similar = cake.similar.map(sid => cakes.find(c => c.id === sid)).filter(Boolean);
            
            document.getElementById('detail-content').innerHTML = `
                <div class="detail-image">
                    ${cake.image ? `<img src="${cake.image}" alt="${cake.name}">` : '<div class="no-image"><span class="no-image">🎂</span></div>'}
                </div>
                <div class="detail-info">
                    <div class="cake-category">${categories[cake.category] || cake.category}</div>
                    <h2 style="color: #111;">${cake.name}</h2>
                    <p style="margin: 15px 0; color: #666;">${cake.desc}</p>
                    <div class="detail-price">${cake.price.toLocaleString()} ₽</div>
                    <div class="detail-fill"><strong>Начинка:</strong> ${cake.fill}</div>
                </div>
                ${similar.length > 0 ? `
                <div class="similar-cakes">
                    <h3>Похожие варианты</h3>
                    <div class="similar-grid">
                        ${similar.map(s => `
                            <div class="similar-item" onclick="showDetail(${s.id})">
                                ${s.image ? `<img src="${s.image}" alt="${s.name}">` : '<div class="no-image"><span class="no-image">🎂</span></div>'}
                                <p>${s.name}</p>
                            </div>
                        `).join('')}
                    </div>
                </div>
                ` : ''}
            `;
            
            document.getElementById('detail-modal').classList.add('show');
        }

        function closeDetail() {
            document.getElementById('detail-modal').classList.remove('show');
            currentDetailCake = null;
        }

        function orderFromDetail() {
            if (currentDetailCake) {
                document.getElementById('order-cake-name').value = currentDetailCake.name;
                document.getElementById('order-modal').classList.add('show');
            }
        }

        function showLogin() {
            document.getElementById('login-modal').classList.add('show');
            document.getElementById('admin-password').value = '';
        }

        function closeLogin() {
            document.getElementById('login-modal').classList.remove('show');
        }

        function checkPassword() {
            if (document.getElementById('admin-password').value === '1698') {
                closeLogin();
                loginAdmin();
            } else {
                alert('Неверный пароль!');
            }
        }

        function loginAdmin() {
            isAdmin = true;
            document.body.classList.add('admin-mode');
            document.getElementById('admin-bar').classList.add('show');
            renderCakes(currentFilter);
            renderNav();
        }

        function logoutAdmin() {
            isAdmin = false;
            document.body.classList.remove('admin-mode');
            document.getElementById('admin-bar').classList.remove('show');
            renderCakes(currentFilter);
            renderNav();
        }

        function deleteCake(id) {
            if (confirm('Удалить торт?')) {
                cakes = cakes.filter(c => c.id !== id);
                saveData();
            }
        }

        function showAddCategory() {
            document.getElementById('new-category-name').value = '';
            document.getElementById('new-category-key').value = '';
            document.getElementById('add-category-modal').classList.add('show');
        }

        function closeAddCategory() {
            document.getElementById('add-category-modal').classList.remove('show');
        }

        function addCategory() {
            const name = document.getElementById('new-category-name').value.trim();
            const key = document.getElementById('new-category-key').value.trim();
            if (name && key) {
                categories[key] = name;
                saveData();
                closeAddCategory();
            }
        }

        function showAddCake(category) {
            tempImage = "";
            document.getElementById('image-preview').innerHTML = '';
            document.getElementById('new-cake-name').value = '';
            document.getElementById('new-cake-desc').value = '';
            document.getElementById('new-cake-fill').value = '';
            document.getElementById('new-cake-price').value = '';
            document.getElementById('new-cake-similar').value = '';
            
            const select = document.getElementById('new-cake-category');
            select.innerHTML = Object.entries(categories).map(([key, name]) => 
                `<option value="${key}" ${key === category ? 'selected' : ''}>${name}</option>`
            ).join('');
            
            document.getElementById('add-cake-modal').classList.add('show');
        }

        function closeAddCake() {
            document.getElementById('add-cake-modal').classList.remove('show');
        }

        function previewImage() {
            const file = document.getElementById('new-cake-image-input').files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    tempImage = e.target.result;
                    document.getElementById('image-preview').innerHTML = `<img src="${tempImage}" style="width:100px;height:100px;object-fit:cover;border-radius:8px;">`;
                };
                reader.readAsDataURL(file);
            }
        }

        function addCake() {
            const name = document.getElementById('new-cake-name').value.trim();
            const category = document.getElementById('new-cake-category').value;
            const desc = document.getElementById('new-cake-desc').value.trim();
            const fill = document.getElementById('new-cake-fill').value.trim();
            const price = parseInt(document.getElementById('new-cake-price').value) || 0;
            const similarStr = document.getElementById('new-cake-similar').value.trim();
            const similar = similarStr ? similarStr.split(',').map(s => parseInt(s.trim())).filter(n => n) : [];
            
            if (name && price > 0) {
                cakes.push({ id: nextId++, name, category, desc, fill, price, similar, image: tempImage });
                saveData();
                closeAddCake();
            }
        }

        function closeOrderModal() {
            document.getElementById('order-modal').classList.remove('show');
        }

        document.getElementById('order-form').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Заявка отправлена! Мы свяжемся с вами.');
            closeOrderModal();
            e.target.reset();
        });

        document.getElementById('order-modal').addEventListener('click', (e) => {
            if (e.target.id === 'order-modal') closeOrderModal();
        });

        renderNav();
        renderCakes();
    </script>
</body>
</html>
