    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

        
        header {
            background: #111111;
            padding: 0;
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: headerAnim 1s ease;
        }
        @keyframes headerAnim {
            from { transform: translateY(-100%); }
            to { transform: translateY(0); }
        }
        .header-inner {
            position: relative;
            z-index: 2;
            padding: 40px 20px 35px;
        }
        .header-swirls {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 1;
        }
        h1 { font-size: 2.5rem; color: #ffffff; margin-bottom: 10px; font-weight: 300; letter-spacing: 4px; text-transform: uppercase; }
        .subtitle { color: #aaaaaa; font-size: 1rem; letter-spacing: 2px; }
        
        nav {
            background: #fff;
            padding: 15px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        nav button {
            background: none;
            border: none;
            padding: 10px 20px;
            margin: 5px;
            cursor: pointer;
            font-size: 1rem;
            color: #111;
            border-radius: 25px;
        }
        nav button:hover, nav button.active { background: #111; color: #fff; }
        nav .add-cat-btn {
            display: none;
            background: #4CAF50;
            color: #fff;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            padding: 0;
            line-height: 35px;
            font-size: 1.3rem;
            margin-left: 10px;
            cursor: pointer;
        }
        body.admin-mode nav .add-cat-btn { display: inline-block; }
        
        main { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .cakes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; }
        
        .cake-card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 3px 15px rgba(0,0,0,0.08);
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            animation: cardPop 0.5s ease backwards;
        }
        .cake-card:nth-child(1) { animation-delay: 0.1s; }
        .cake-card:nth-child(2) { animation-delay: 0.15s; }
        .cake-card:nth-child(3) { animation-delay: 0.2s; }
        .cake-card:nth-child(4) { animation-delay: 0.25s; }
        .cake-card:nth-child(5) { animation-delay: 0.3s; }
        .cake-card:nth-child(6) { animation-delay: 0.35s; }
        .cake-card:nth-child(7) { animation-delay: 0.4s; }
        .cake-card:nth-child(8) { animation-delay: 0.45s; }
        
        @keyframes cardPop {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }
        .cake-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15); }
        
        .add-card-btn {
            display: none;
            background: #f5f5f5;
            border: 2px dashed #ccc;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s;
            min-height: 280px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #999;
            font-size: 3rem;
        }
        .add-card-btn:hover { border-color: #4CAF50; color: #4CAF50; }
        body:not(.admin-mode) .add-card-btn { display: none !important; }
        body.admin-mode .add-card-btn { display: flex !important; }
        
        .cake-card .delete-btn {
            display: none;
            position: absolute;
            top: 10px;
            right: 10px;
            background: #ff4444;
            color: #fff;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.2rem;
            z-index: 10;
        }
        .admin-bar.show ~ header, 
        .admin-bar.show ~ nav, 
        .admin-bar.show ~ main {
            margin-top: 50px;
        }
        body.admin-mode .cake-card .delete-btn { display: block; }
        
        .cake-image {
            width: 100%;
            height: 200px;
            background: #e8d5c4;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .cake-image img { width: 100%; height: 100%; object-fit: cover; }
        .cake-image .no-image { font-size: 3rem; color: #aaa; }
        
        .cake-info { padding: 20px; }
        .cake-category { font-size: 0.8rem; color: #888; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px; }
        .cake-name { font-size: 1.3rem; color: #111; margin-bottom: 5px; }
        .cake-desc { color: #666; font-size: 0.9rem; line-height: 1.5; margin-bottom: 10px; }
        .cake-price { font-size: 1.4rem; color: #111; font-weight: bold; }
        
        footer { background: #111; color: #ccc; padding: 30px 20px; text-align: center; }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal.show { display: flex; }
        .modal-content {
            background: #fff;
            padding: 30px;
            border-radius: 15px;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal h2 { color: #111; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; color: #111; }
        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
        }
        .modal-buttons { display: flex; gap: 10px; }
        .modal-buttons button {
            flex: 1;
