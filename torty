    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #ffffff; color: #333; }
        
        .admin-bar {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 10px 20px;
            background: #333;
            justify-content: space-between;
            align-items: center;
            z-index: 300;{
  "name": "torty-website",
  "version": "1.0.0",
  "description": "Сайт тортов на заказ",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  }
}

        }
        .admin-bar.show { display: flex; }
        .admin-bar span { color: #fff; font-size: 0.9rem; }
        .admin-close-btn {
            background: #ff4444;
            color: #fff;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cakes", "dest": "/api/cakes.js" },
    { "src": "/api/cakes/(.*)", "dest": "/api/cakes/[id].js" },
    { "src": "/api/categories", "dest": "/api/categories.js" },
